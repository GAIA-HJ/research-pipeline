# OpenAlex (free, get key at openalex.org)
OPENALEX_API_KEY=your_openalex_key_here
OPENALEX_EMAIL=your_email@example.com

# AI Model for Article Generation
# Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_API_KEY=your_anthropic_or_openai_key_here
LLM_MODEL=claude-sonnet-4-20250514

# Blockchain Anchoring (optional)
# Leave POLYGON_PRIVATE_KEY empty to skip blockchain
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=

# Your Website
SITE_DIR=./website
SITE_URL=https://yoursite.com
AUTHOR_NAME=Your Name
JOURNAL_NAME=Your Research Review

# Pipeline
ARTICLES_PER_CYCLE=3
OUTPUT_DIR=./output
EVIDENCE_DB_PATH=./evidence.db
